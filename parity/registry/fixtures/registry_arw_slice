# Dependency-closed WRF Registry fixture for the Rust parser and preprocessor.
# Includes and conditionals follow the production Registry.EM layout: the
# dimension specifications and the shared collection arrive through includes,
# and ifdef blocks select entries by whole -D symbol strings.
include registry.dimspec_slice
include registry.em_shared_slice

ifdef PARITY_SLICE=1
state real qv_slice ikj dyn_em 2 - i0rh "QV_SLICE" \
    "conditional moisture slice selected by -DPARITY_SLICE=1" "kg kg-1"
endif

ifdef UNSET_FEATURE=1
state real ghost ikj dyn_em 1 - i0 "GHOST" \
    "must never reach generated artifacts" "K"
endif

ifndef UNSET_FEATURE=1
rconfig integer unset_feature_default namelist,domains 1 7 - UNSET_FEATURE_DEFAULT \
    "Selected because the feature symbol is absent" "flag"
endif

ifndef PARITY_SLICE=1
rconfig integer ghost_ifndef namelist,domains 1 0 - GHOST_IFNDEF \
    "Must be rejected because the parity symbol is defined" "flag"
endif
