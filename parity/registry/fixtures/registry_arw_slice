# Dependency-closed WRF Registry fixture for the first Rust parser slice.
dimspec i 1 standard_domain x west_east
dimspec k 2 standard_domain z bottom_top
dimspec j 3 standard_domain y south_north
dimspec l 2 namelist=bottom_top z configured_levels
dimspec m 2 constant=12 z months_per_year
dimspec z - constant=(-3:3) c -

rconfig integer bottom_top namelist,domains 1 50 - BOTTOM-TOP \
    "Model top index" "index"
rconfig integer start_year namelist,time_control max_domains 1993 - START_YEAR \
    "Four-digit start year" "year"
rconfig real dt derived max_domains 2. h "dt" \
    "TEMPORAL RESOLUTION" "SECONDS"
rconfig logical restart namelist,time_control 1 .false. - RESTART \
    "Whether this is a restart" "flag"
rconfig character*256 input_name namelist,time_control 1 "wrfinput_d<domain>" - INPUT_NAME \
    "Case-preserving input path" "path"

state real t ikjb dyn_em 2 - \
    i0rhusdf=(bdy_interp:dt) "thm" \
    "either 1) pert moist pot temp=(1+Rv/Rd Qv)*(theta)-T0, or 2) pert dry pot temp=theta-T0; based on use_theta_m setting" "K"
state real mu ijb dyn_em 2 - \
    irh01usdf=(bdy_interp:dt) "mu" \
    "perturbation dry air mass in column" "Pa"
